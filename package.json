{
  "name": "one-truth-cue",
  "displayName": "One Truth Cue",
  "description": "Play character-style sound cues when VS Code commands succeed, fail, or emit warnings.",
  "version": "0.0.1",
  "publisher": "YukiOgata",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YukiOgata-tech/VScode-extension-01.git"
  },
  "bugs": {
    "url": "https://github.com/YukiOgata-tech/VScode-extension-01/issues"
  },
  "homepage": "https://github.com/YukiOgata-tech/VScode-extension-01#readme",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "sound",
    "cue",
    "detective",
    "build",
    "notification",
    "shell"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "oneTruthCue.testErrorSound",
        "title": "One Truth Cue: Test Error Cue"
      },
      {
        "command": "oneTruthCue.testWarningSound",
        "title": "One Truth Cue: Test Warning Cue"
      },
      {
        "command": "oneTruthCue.testSuccessSound",
        "title": "One Truth Cue: Test Success Cue"
      },
      {
        "command": "oneTruthCue.selectSoundMode",
        "title": "One Truth Cue: Select Cue Mode"
      },
      {
        "command": "oneTruthCue.nextSoundMode",
        "title": "One Truth Cue: Next Cue Mode"
      },
      {
        "command": "oneTruthCue.toggleEnabled",
        "title": "One Truth Cue: Toggle Enabled"
      },
      {
        "command": "oneTruthCue.showLastIssue",
        "title": "One Truth Cue: Show Last Detected Issue"
      }
    ],
    "configuration": {
      "title": "One Truth Cue",
      "properties": {
        "oneTruthCue.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable command sound cues."
        },
        "oneTruthCue.playOnSuccess": {
          "type": "boolean",
          "default": false,
          "description": "Play a sound when a terminal command succeeds with exit code 0."
        },
        "oneTruthCue.includeWarnings": {
          "type": "boolean",
          "default": false,
          "description": "Play a sound for warning-only terminal output."
        },
        "oneTruthCue.treatUnknownExitCodeAsError": {
          "type": "boolean",
          "default": false,
          "description": "Treat undefined terminal exit codes as errors."
        },
        "oneTruthCue.showNotification": {
          "type": "boolean",
          "default": false,
          "description": "Show a VS Code notification when an issue is detected."
        },
        "oneTruthCue.errorSoundFile": {
          "type": "string",
          "default": "error.mp3",
          "description": "Sound file name under the extension's media directory for errors."
        },
        "oneTruthCue.warningSoundFile": {
          "type": "string",
          "default": "warning.mp3",
          "description": "Sound file name under the extension's media directory for warnings."
        },
        "oneTruthCue.successSoundFile": {
          "type": "string",
          "default": "warning.mp3",
          "description": "Sound file name under the extension's media directory for successful commands."
        },
        "oneTruthCue.soundMode": {
          "type": "string",
          "default": "default",
          "description": "Active cue mode. Use One Truth Cue: Select Cue Mode or Next Cue Mode to change it."
        },
        "oneTruthCue.soundModes": {
          "type": "object",
          "default": {
            "default": {
              "errorSoundFile": "mode1/error.mp3",
              "warningSoundFile": "mode1/warning.mp3",
              "successSoundFile": "mode1/success.mp3"
            },
            "mode1": {
              "errorSoundFile": "mode1/error.mp3",
              "warningSoundFile": "mode1/warning.mp3",
              "successSoundFile": "mode1/success.mp3"
            },
            "mode2": {
              "errorSoundFile": "mode2/error.mp3",
              "warningSoundFile": "mode2/warning.mp3",
              "successSoundFile": "mode2/success.mp3"
            }
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "errorSoundFile": {
                "type": "string"
              },
              "warningSoundFile": {
                "type": "string"
              },
              "successSoundFile": {
                "type": "string"
              }
            }
          },
          "description": "Named sound modes. Each file name is resolved under the extension's media directory."
        },
        "oneTruthCue.cooldownMs": {
          "type": "number",
          "default": 800,
          "minimum": 0,
          "description": "Minimum interval between sound playback in milliseconds."
        },
        "oneTruthCue.maxOutputChars": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "description": "Maximum number of terminal output characters stored per command."
        },
        "oneTruthCue.ignoredCommands": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Command substrings to ignore. If a command line contains any of these strings, no sound is played."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vscode/vsce": "^3.2.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "sound-play": "^1.1.0"
  }
}
